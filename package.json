{
  "name": "better-end-line-actions",
  "displayName": "better end line actions",
  "description": "",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lineFix.deleteLines",
        "title": "Delete Lines (Fixed)"
      },
      {
        "command": "lineFix.copyLinesUp",
        "title": "Copy Lines Up (Fixed)"
      },
      {
        "command": "lineFix.copyLinesDown",
        "title": "Copy Lines Down (Fixed)"
      },
      {
        "command": "lineFix.moveLinesUp",
        "title": "Move Lines Up (Fixed)"
      },
      {
        "command": "lineFix.moveLinesDown",
        "title": "Move Lines Down (Fixed)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
